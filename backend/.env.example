# Groq  →  https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini  →  https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude  →  https://console.anthropic.com/settings/api-keys
CLAUDE_API_KEY=your_claude_api_key_here

PORT=3001

# Origins allowed to call this proxy (comma-separated, no trailing slash)
# For local Expo dev: http://localhost:8081
# For physical device on LAN: http://192.168.x.x:8081
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
